{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "image",
    "serviceAccount",
    "podSecurityContext",
    "containerSecurityContext",
    "resources",
    "livenessProbe",
    "readinessProbe"
  ],
  "properties": {
    "image": {
      "type": "object",
      "required": [
        "repository",
        "digest"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1,
          "description": "コンテナイメージのリポジトリ（必須・空文字不可）"
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "コンテナイメージの sha256 ダイジェスト（必須・形式: sha256:<64桁の16進数>）"
        },
        "pullPolicy": {
          "type": "string",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ]
        }
      }
    },
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": {
          "type": "boolean"
        },
        "annotations": {
          "type": "object"
        },
        "name": {
          "type": "string"
        },
        "automountToken": {
          "type": "boolean"
        }
      }
    },
    "rbac": {
      "type": "object",
      "properties": {
        "create": {
          "type": "boolean"
        }
      }
    },
    "podSecurityContext": {
      "type": "object"
    },
    "containerSecurityContext": {
      "type": "object"
    },
    "resources": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          }
        }
      }
    },
    "podAnnotations": {
      "type": "object"
    },
    "podLabels": {
      "type": "object"
    },
    "nodeSelector": {
      "type": "object"
    },
    "tolerations": {
      "type": "array"
    },
    "affinity": {
      "type": "object"
    },
    "topologySpreadConstraints": {
      "type": "array"
    },
    "priorityClassName": {
      "type": "string"
    },
    "dnsPolicy": {
      "type": "string",
      "enum": [
        "ClusterFirst",
        "ClusterFirstWithHostNet",
        "Default",
        "None"
      ]
    },
    "dnsConfig": {
      "type": "object"
    },
    "initContainers": {
      "type": "array"
    },
    "terminationGracePeriodSeconds": {
      "type": "integer",
      "minimum": 0
    },
    "extraEnv": {
      "type": "array"
    },
    "extraEnvFrom": {
      "type": "array"
    },
    "extraVolumeMounts": {
      "type": "array"
    },
    "extraVolumes": {
      "type": "array"
    },
    "extraLabels": {
      "type": "object"
    },
    "imagePullSecrets": {
      "type": "array"
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "livenessProbe": {
      "type": "object"
    },
    "readinessProbe": {
      "type": "object"
    },
    "startupProbe": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "updateStrategy": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "RollingUpdate",
            "OnDelete"
          ]
        },
        "rollingUpdate": {
          "type": "object",
          "properties": {
            "maxUnavailable": {
              "oneOf": [
                {
                  "type": "integer",
                  "minimum": 0
                },
                {
                  "type": "string"
                }
              ]
            },
            "maxSurge": {
              "oneOf": [
                {
                  "type": "integer",
                  "minimum": 0
                },
                {
                  "type": "string"
                }
              ]
            }
          }
        }
      }
    },
    "revisionHistoryLimit": {
      "type": "integer",
      "minimum": 0
    },
    "hostNetwork": {
      "type": "boolean"
    },
    "hostPID": {
      "type": "boolean"
    },
    "service": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "type": {
          "type": "string",
          "enum": [
            "ClusterIP",
            "NodePort",
            "LoadBalancer"
          ]
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "containerPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "portName": {
          "type": "string"
        },
        "protocol": {
          "type": "string",
          "enum": [
            "TCP",
            "UDP",
            "SCTP"
          ]
        }
      }
    }
  }
}